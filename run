#!/usr/bin/env bash
set -euo pipefail

script_dir="$( cd "$( dirname "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )"

if [[ -z "${DEV_ENV:-}" ]]; then
    echo "env var DEV_ENV needs to be present"
    exit 1
fi

# if i just did DEV_ENV=$(pwd) ./run then this is needed for the rest of the
# scripts
export DEV_ENV="$DEV_ENV"

grep=""
dry_run="0"

while [[ $# -gt 0 ]]; do
    if [[ "$1" == "--dry" || "$1" == "--dry-run" ]]; then
        dry_run="1"
    else
        # Only the first non-flag is used as the filter (e.g. ./run --dry rust)
        [[ -z "$grep" ]] && grep="$1"
    fi
    shift
done

log() {
    if [[ "$dry_run" == "1" ]]; then
        echo "[DRY_RUN]: $*"
    else
        echo "$*"
    fi
}

log "RUN: env: $DEV_ENV -- grep: $grep"

while IFS= read -r -d '' s; do
    if [[ -n "$grep" ]] && ! basename "$s" | grep -q "$grep"; then
        log "grep \"$grep\" filtered out $s"
        continue
    fi

    log "running script: $s"

    if [[ "$dry_run" == "0" ]]; then
        "$s"
    fi
done < <(find "$script_dir/runs" -mindepth 1 -maxdepth 1 -executable -print0 | sort -z)
