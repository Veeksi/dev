#!/usr/bin/env bash
set -euo pipefail

dry_run="0"

# XDG default
if [[ -z "${XDG_CONFIG_HOME:-}" ]]; then
    echo "no xdg config home"
    echo "using ~/.config"
    XDG_CONFIG_HOME="$HOME/.config"
fi

# Require DEV_ENV
if [[ -z "${DEV_ENV:-}" ]]; then
    echo "env var DEV_ENV needs to be present"
    exit 1
fi

if [[ "${1:-}" == "--dry" ]]; then
    dry_run="1"
fi

log() {
    if [[ "$dry_run" == "1" ]]; then
        echo "[DRY_RUN]: $1"
    else
        echo "$1"
    fi
}

log "env: $DEV_ENV"

sync_dir() {
    local src="$1"
    local dst="$2"

    log "syncing: $src -> $dst"
    mkdir -p "$dst"

    if [[ "$dry_run" == "0" ]]; then
        rsync -a --delete "$src/" "$dst/"
    else
        rsync -a --delete --dry-run "$src/" "$dst/"
    fi
}

copy_file() {
    local src="$1"
    local dst="$2"

    log "removing: $dst"
    if [[ "$dry_run" == "0" ]]; then
        rm -f "$dst"
    fi

    log "copying: $src to $dst"
    if [[ "$dry_run" == "0" ]]; then
        cp "$src" "$dst"
    fi
}

# Sync config dirs
sync_dir "$DEV_ENV/env/.config" "$XDG_CONFIG_HOME"

# Copy dotfiles
# copy_file "$DEV_ENV/env/.zsh_profile" "$HOME/.zsh_profile"
copy_file "$DEV_ENV/env/.zshrc" "$HOME/.zshrc"
copy_file "$DEV_ENV/env/.vimrc" "$HOME/.vimrc"
copy_file "$DEV_ENV/env/.ideavimrc" "$HOME/.ideavimrc"

# Reload Hyprland if available (skip in dry-run)
if [[ "$dry_run" == "0" ]] && command -v hyprctl >/dev/null 2>&1; then
    hyprctl reload || true
fi

log "ok"
