#!/usr/bin/env bash
set -euo pipefail

dry_run="0"

# XDG default
if [[ -z "${XDG_CONFIG_HOME:-}" ]]; then
    echo "no xdg config home"
    echo "using ~/.config"
    XDG_CONFIG_HOME="$HOME/.config"
fi

# Require DEV_ENV
if [[ -z "${DEV_ENV:-}" ]]; then
    echo "env var DEV_ENV needs to be present"
    exit 1
fi

if [[ "${1:-}" == "--dry" || "${1:-}" == "--dry-run" ]]; then
    dry_run="1"
fi

log() {
    if [[ "$dry_run" == "1" ]]; then
        echo "[DRY_RUN]: $1"
    else
        echo "$1"
    fi
}

log "env: $DEV_ENV"

sync_dir() {
    local src="$1"
    local dst="$2"

    log "syncing: $src -> $dst"
    if [[ "$dry_run" == "0" ]]; then
        mkdir -p "$dst"
        rsync -a --delete "$src/" "$dst/"
    else
        rsync -a --delete --dry-run "$src/" "$dst/"
    fi
}

sync_config_entries() {
    local src="$1"
    local dst="$2"

    for entry in "$src"/*; do
        local name
        name="$(basename "$entry")"

        if [[ -d "$entry" ]]; then
            sync_dir "$entry" "$dst/$name"
        elif [[ -f "$entry" ]]; then
            copy_file "$entry" "$dst/$name"
        fi
    done
}

copy_file() {
    local src="$1"
    local dst="$2"

    log "removing: $dst"
    if [[ "$dry_run" == "0" ]]; then
        if [[ -d "$dst" ]]; then
            rm -rf "$dst"
        else
            rm -f "$dst"
        fi
    fi

    log "copying: $src to $dst"
    if [[ "$dry_run" == "0" ]]; then
        cp "$src" "$dst"
    fi
}

# Sync each config entry individually so unmanaged configs are preserved
sync_config_entries "$DEV_ENV/env/.config" "$XDG_CONFIG_HOME"

# Copy dotfiles
copy_file "$DEV_ENV/env/.zshrc" "$HOME/.zshrc"
copy_file "$DEV_ENV/env/.vimrc" "$HOME/.vimrc"
copy_file "$DEV_ENV/env/.ideavimrc" "$HOME/.ideavimrc"

# Reload Hyprland if available (skip in dry-run)
if [[ "$dry_run" == "0" ]] && command -v hyprctl >/dev/null 2>&1; then
    hyprctl reload || true
fi

log "ok"
